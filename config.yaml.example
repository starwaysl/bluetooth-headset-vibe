# Bluetooth Headset Vibe 配置文件
# 复制为 config.yaml 并修改为你自己的设置

# ── 触发键配置 ──────────────────────────────────────────
#
# 小米电视蓝牙遥控器（或其他蓝牙 HID 设备）的按键映射。
# 用 pynput 监听键盘事件，当检测到指定按键时触发对应动作。
#
# 如何知道你的遥控器按键名？
#   运行 probe_remote.py，按遥控器，终端会显示 keyCode。
#   把 keyCode 里的名字填在这里（如 Key.f5、Key.enter、Key.cmd_r 等）。

triggers:
  # 按哪个键触发语音输入（启动微信/豆包/讯飞的语音面板）
  # 示例：Key.enter（回车）、Key.f5、Key.home 等
  voice_input: "Key.enter"

  # 按哪个键把当前输入框文字发给 AI
  # 示例：Key.f5、Key.cmd_r（右 Command）、Key.f6 等
  send_to_ai: "Key.f5"

# ── 输入法语音快捷键 ──────────────────────────────────────
#
# 微信/豆包/讯飞 的语音输入快捷键。
# 当触发 voice_input 键时，脚本会模拟按下这个快捷键。
#
# 格式：用 + 连接修饰符和键名
# 修饰符：cmd, opt, ctrl, shift
# 键名：a-z, 0-9, space, return, tab 等
#
# 常见输入法默认快捷键：
#   微信输入法：opt+cmd+s
#   豆包输入法：（请在输入法设置中查看）
#   讯飞输入法：（请在输入法设置中查看）
keyboard_shortcut:
  voice_input: "opt+cmd+s"

# ── AI 后端配置 ──────────────────────────────────────────
ai:
  # 可选：claude | openai | custom
  provider: "claude"

  # API Key
  # Claude: 从 https://console.anthropic.com/settings/keys 获取
  # OpenAI: 从 https://platform.openai.com/api-keys 获取
  api_key: "YOUR_API_KEY_HERE"

  # 模型选择
  # Claude: claude-opus-4-8 | claude-sonnet-5 | claude-haiku-4-5-20251001
  # OpenAI: gpt-4o | gpt-4o-mini
  model: "claude-sonnet-5"

  # 仅当 provider 为 custom 时使用
  # base_url: "https://your-compatible-api.com/v1"

# ── AI 系统提示词 ────────────────────────────────────────
system_prompt: |
  你是一个 Vibe Coding 助手。用户通过语音输入描述他们想要的代码操作。
  请用简洁的中文回答，直接给出代码片段或操作指令，不要废话。
  如果用户的请求不明确，主动询问细节。

# ── 调试模式 ────────────────────────────────────────────
# 开启后打印详细日志（包括每个按键事件、API 请求详情等）
debug: false
